NODE_ENV=development
PORT=3333
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/rlburger
DIRECT_URL=postgresql://postgres:postgres@localhost:5434/rlburger
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
JWT_SECRET=change-me-with-at-least-10-characters

# Railway
# Set these in the Railway backend service:
# NODE_ENV=production
# PORT=${{PORT}}
# DATABASE_URL=<Railway Postgres connection URL>
# DIRECT_URL=<Railway Postgres direct/private URL if available, otherwise same as DATABASE_URL>
# FRONTEND_URL=https://your-frontend-domain.vercel.app
# CORS_ORIGINS=https://your-frontend-domain.vercel.app,https://your-custom-domain.com
# JWT_SECRET=<strong random secret>

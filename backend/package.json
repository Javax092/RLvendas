{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npm run prisma:generate && tsc -p tsconfig.json",
    "railway:build": "npm run prisma:generate && tsc -p tsconfig.json",
    "postinstall": "npm run prisma:generate",
    "start": "node dist/server.js",
    "railway:start": "npm run prisma:migrate:deploy && npm run start",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "DIRECT_URL=${DIRECT_URL:-$DATABASE_URL} prisma migrate deploy",
    "prisma:generate": "DIRECT_URL=${DIRECT_URL:-$DATABASE_URL} prisma generate",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "test": "node --import tsx --test tests/**/*.test.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "6.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.2",
    "morgan": "^1.10.0",
    "slugify": "^1.6.6",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.13.10",
    "prisma": "6.6.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
